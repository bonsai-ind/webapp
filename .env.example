# Bonsai / Hush — frontend environment (Vite)
#
# Copy to `.env.local` and adjust. Only `VITE_`-prefixed variables are exposed to
# the client bundle (Vite convention) — never put secrets here.

# Base URL of the Bonsai api-gateway (the public edge the SPA talks to).
# Falls back to http://localhost:8080 when unset (see src/main.tsx).
#   local dev:   http://localhost:8080
#   production:  https://api.<your-domain>
VITE_API_BASE_URL=http://localhost:8080
